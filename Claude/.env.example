# ── Snowflake connection (external-browser SSO for dev) ──────────────────────
# Your account identifier, e.g. abcd-xy12345  (from the account URL: <ACCOUNT>.snowflakecomputing.com)
SNOWFLAKE_ACCOUNT=your-account-identifier

# The login name your IdP maps to (often your work email)
SNOWFLAKE_USER=you@company.com

# Auth method: externalbrowser triggers SSO via your default browser.
SNOWFLAKE_AUTHENTICATOR=externalbrowser

# No new roles are being created for this project — use one of your EXISTING
# org-assigned roles. Run discover_access.py first to list what you have, then
# pick the one that can SELECT the source data but ideally cannot write to it.
# Leave blank to use your account default role.
SNOWFLAKE_ROLE=

# Warehouse used to run scan/profile/rule queries. Run discover_access.py to list
# warehouses you can use.
SNOWFLAKE_WAREHOUSE=

# Optional defaults; agents override per query anyway.
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# ── App-owned DB (full access) — where the platform stores its own state ─────
# Use an existing role + database where you're allowed to CREATE TABLE (e.g. a
# personal/sandbox database). Leave APP_SNOWFLAKE_ROLE blank to reuse SNOWFLAKE_ROLE.
APP_SNOWFLAKE_ROLE=
APP_SNOWFLAKE_DATABASE=
APP_SNOWFLAKE_SCHEMA=PUBLIC

# ── Claude via Amazon Bedrock (LLM-based rule recommendation) ────────────────
# This account only has legacy bedrock-runtime:InvokeModel access, not the
# newer bedrock-mantle:CreateInference permission -- tools/claude_tools.py
# uses the AnthropicBedrock client (legacy path), not AnthropicBedrockMantle.
# Bearer-token auth: the SDK reads this env var automatically, no code change
# needed if it's set in the shell/OS environment already.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-2

# ── LangSmith (agent/LLM tracing) ─────────────────────────────────────────────
# Optional -- tools/langsmith_tools.py no-ops entirely if LANGSMITH_API_KEY is
# unset, so the app runs fine without this. Get a free key at smith.langchain.com.
# Traces the LangGraph workflow (graphs/dq_workflow_graph.py) and every
# Claude/Bedrock call (tools/claude_tools.py).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-dq-platform
