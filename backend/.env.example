# Snowflake — app storage (assets/scans/findings/rules/etc.) lives in
# SNOWFLAKE_APP_SCHEMA inside SNOWFLAKE_DATABASE. No separate app database —
# just one schema, separate from whatever source data gets scanned.
# For SSO: Set AUTH_METHOD=externalbrowser and leave PASSWORD empty
# For password auth: Set AUTH_METHOD=password and provide PASSWORD
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=PLAYGROUND_DB
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=
SNOWFLAKE_AUTH_METHOD=externalbrowser
SNOWFLAKE_APP_SCHEMA=DQ_APP

# API
API_V1_STR=/api/v1
PROJECT_NAME=Data Quality Platform

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# Environment
ENVIRONMENT=development
